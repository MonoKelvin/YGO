{
  "name": "ygo",
  "version": "1.0.0",
  "description": "游戏王卡牌生成器",
  "main": "electron/main.cjs",
  "scripts": {
    "renderer:dev": "vite --port 5173",
    "desktop:dev": "concurrently -k \"npm run renderer:dev\" \"npm run electron:wait\"",
    "electron:wait": "wait-on http-get://localhost:5173 http-get://localhost:5174 http-get://localhost:5175 http-get://localhost:5176 http-get://localhost:5177 http-get://localhost:5178 http-get://localhost:5179 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "desktop:dev:renderer": "npm run renderer:dev",
    "build": "vite build && node copy-assets.js",
    "desktop:build": "npm run build && electron-builder",
    "desktop:pack": "npm run build && electron-builder --dir",
    "start": "npm run desktop:dev",
    "dev": "npm run desktop:dev"
  },
  "keywords": [
    "electron",
    "react",
    "yugioh",
    "card-generator"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@lobehub/ui": "^1.170.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.ygo.app",
    "productName": "YGO",
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "src/assets",
        "to": "assets",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false,
      "icon": "src/assets/app/logo-256x256.png"
    },
    "nsis": {
      "oneClick": true,
      "allowElevation": true,
      "installerIcon": "src/assets/app/logo-256x256.png",
      "uninstallerIcon": "src/assets/app/logo-256x256.png",
      "installerHeaderIcon": "src/assets/app/logo-256x256.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YGO"
    }
  },
  "type": "module"
}
