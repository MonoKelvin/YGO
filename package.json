{
  "name": "ygo",
  "version": "1.0.0",
  "description": "游戏王卡牌生成器",
  "main": "electron/main.cjs",
  "scripts": {
    "vite:dev": "vite",
    "electron:dev": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev": "concurrently -k -n \"vite,electron\" -c \"cyan,magenta\" \"npm run vite:dev\" \"npm run electron:dev\"",
    "desktop:dev": "npm run dev",
    "renderer:dev": "npm run vite:dev",
    "build": "cross-env NODE_ENV=production vite build --mode production",
    "desktop:build": "npm run icons:prepare && npm run build && electron-builder",
    "desktop:pack": "npm run icons:prepare && npm run build && electron-builder --dir",
    "package:release": "node scripts/package-release.mjs",
    "icons:prepare": "node scripts/ensure-app-icons.mjs",
    "start": "npm run dev",
    "mold:check": "node scripts/mold-check.mjs",
    "cards:fetch": "node scripts/fetch-ygoprodeck.mjs",
    "cards:fetch:images": "node scripts/fetch-ygoprodeck.mjs --images"
  },
  "keywords": [
    "electron",
    "react",
    "yugioh",
    "card-generator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/icons": "^5.8.0",
    "@lobehub/ui": "^5.10.2",
    "antd": "^6.3.7",
    "lucide-react": "^0.484.0",
    "motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.3",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^26.8.2",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "vite": "^5.4.11",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.ygo.app",
    "productName": "YGO",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/sql.js/**/*"
    ],
    "asarUnpack": [
      "node_modules/sql.js/**/*"
    ],
    "extraResources": [
      {
        "from": "src/assets",
        "to": "assets",
        "filter": [
          "app/**/*",
          "docs/**/*",
          "cards/**/*"
        ]
      }
    ],
    "afterPack": "./scripts/after-pack-win-icon.cjs",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.games",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "nsis": {
      "include": "scripts/nsis/installer.nsh",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YGO",
      "runAfterFinish": true,
      "license": "LICENSE",
      "warningsAsErrors": true,
      "unicode": true,
      "language": "2052",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "artifactName": "ygo-setup-${version}.${ext}"
    }
  },
  "type": "module"
}
